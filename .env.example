# ──────────────────────────────────────────────────
# Local Development Environment
# ──────────────────────────────────────────────────
# Copy this file to .env and adjust values as needed.
# These values are used when running with `sls offline start`.
# They align with docker-compose.yml and serverless.yml defaults.

# Signals serverless-offline mode — switches SDK clients to local endpoints
IS_OFFLINE=true

# ──────────────────────────────────────────────────
# AWS
# ──────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ──────────────────────────────────────────────────
# DynamoDB Local (docker-compose: amazon/dynamodb-local)
# ──────────────────────────────────────────────────
TASKS_TABLE=tasks-dev

# ──────────────────────────────────────────────────
# ElasticMQ / SQS (docker-compose: softwaremill/elasticmq-native)
# ──────────────────────────────────────────────────
SQS_ENDPOINT=http://localhost:9324
TASK_QUEUE_NAME=task-queue-dev
TASK_QUEUE_URL=http://localhost:9324/000000000000/task-queue-dev
